# Pi-Drive Wi-Fi Access Point (fallback when no LAN Wi-Fi is connected)
# Copy to hostapd.conf and set your SSID and passphrase (min 8 chars)
interface=wlan0
driver=nl80211
ssid=YOUR_AP_SSID
hw_mode=g
channel=6
wmm_enabled=0
macaddr_acl=0
auth_algs=1
ignore_broadcast_ssid=0
wpa=2
wpa_passphrase=YOUR_AP_PASSWORD
wpa_key_mgmt=WPA-PSK
wpa_pairwise=TKIP
rsn_pairwise=CCMP
